# API Settings
OLLAMA_MODEL=llama3
MAX_TOKENS=150
TEMPERATURE=0.3

# Scraping Settings
MAX_REVIEWS=50
REQUEST_DELAY=0.5
MAX_RETRIES=3

# File Export Settings
EXPORT_FORMAT=csv

# Optional: BrightData Configuration (if using BrightData instead of local Selenium)
# SBR_WEBDRIVER=https://brd-customer-hl_xxxxxx-zone-scraping_browser:your_password@brd.superproxy.io:9515

# Optional: OpenAI API (if you want to use OpenAI instead of Ollama)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo